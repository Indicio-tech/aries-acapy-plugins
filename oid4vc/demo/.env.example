# demo/.env.example — copy to .env and update as needed
#
#   cp .env.example .env
#
# All values below are the defaults used when the variable is unset.
# Only change lines that differ from your local setup.

# ── ACA-Py host port bindings ───────────────────────────────────────────────
# The admin APIs and OID4VC endpoints are exposed on the host for easy curl
# access and for the local Playwright demo script.

ACAPY_ISSUER_ADMIN_PORT=8021
ACAPY_ISSUER_OID4VCI_PORT=8022

ACAPY_VERIFIER_ADMIN_PORT=8031
ACAPY_VERIFIER_OID4VP_PORT=8032

# ── Walt.id wallet port ─────────────────────────────────────────────────────
# The nginx proxy combines the wallet frontend and API on this port.
WALLET_PORT=7101

# ── Docker platform ─────────────────────────────────────────────────────────
# Default linux/arm64 (Apple Silicon native for ACA-Py).
# Set to linux/amd64 to force emulation (required for walt.id images, which
# Docker Desktop handles automatically via Rosetta).
# DOCKER_PLATFORM=linux/amd64

# ── Log level ───────────────────────────────────────────────────────────────
# LOG_LEVEL=info    # info | debug | warning | error

# ── Localhost defaults (no changes needed for local demo) ───────────────────
#
# When running fully locally, the credential_issuer URLs in offered credentials
# use docker-internal hostnames (acapy-issuer.local, acapy-verifier.local) so
# that the waltid-wallet-api container can reach ACA-Py directly inside the
# Docker network.  Your browser reaches the wallet at http://localhost:7101 and
# the admin APIs at http://localhost:8021 / http://localhost:8031.
#
# No HTTPS is required for localhost operation.

# ── zrok public tunnel endpoints (optional) ─────────────────────────────────
#
# Use zrok when you want to demo to real mobile wallets or share the demo over
# the internet.  zrok provides free HTTPS tunnels — no nginx TLS proxy needed.
#
# 1. Install zrok:  https://docs.zrok.io/docs/getting-started
# 2. Reserve permanent tunnel names once (lowercase alphanumeric, 4-32 chars):
#
#    zrok reserve public --unique-name "myissuerapi"  http://localhost:8022
#    zrok reserve public --unique-name "myverifierapi" http://localhost:8032
#    zrok reserve public --unique-name "mydemowallet"  http://localhost:7101
#
# 3. Activate all tunnels each session (in separate terminals):
#
#    zrok share reserved myissuerapi
#    zrok share reserved myverifierapi
#    zrok share reserved mydemowallet
#
# 4. Uncomment and fill in the URLs below, then restart docker compose:
#
# Public URL embedded in credential offers (must be reachable by wallets).
# ISSUER_OID4VCI_ENDPOINT=https://myissuerapi.share.zrok.io
#
# Public URL embedded in presentation requests.
# VERIFIER_OID4VP_ENDPOINT=https://myverifierapi.share.zrok.io
#
# Public URL of the walt.id web wallet (used by NUXT_PUBLIC_ISSUER_CALLBACK_URL).
# WALLET_PUBLIC_URL=https://mydemowallet.share.zrok.io
